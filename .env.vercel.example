# Vercel environment variables template
# Copy this file to .env.vercel and fill in your Railway service URLs.
#
# Usage:
#   cp .env.vercel.example .env.vercel
#   Edit .env.vercel with your real values
#   Run: .\scripts\push-env-to-vercel.ps1

COMPUTE_SERVICE_URL=https://your-compute-service.up.railway.app
HISTORY_SERVICE_URL=https://your-history-service.up.railway.app
